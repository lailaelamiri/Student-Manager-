<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F0E8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#3B2F2F"
        android:paddingTop="32dp"
        android:paddingBottom="20dp"
        android:paddingLeft="24dp"
        android:paddingRight="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SCHOLAR ROSTER"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#F5F0E8"
            android:letterSpacing="0.2"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap a scholar to edit or remove"
            android:textSize="12sp"
            android:textColor="#9E8B7D"
            android:gravity="center"
            android:paddingTop="4dp" />

    </LinearLayout>

    <ListView
        android:id="@+id/scholarListView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="#E8DDD0"
        android:dividerHeight="1dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

</LinearLayout>